PORT=3000

# --- AWS / Bedrock (Sparkathon account 710894194408) ---
AWS_REGION=us-east-1

# Use the federated SSO profile created by MSEntraAuthAWSCLI.
# The AWS SDK will read this from process.env and resolve
# credentials from ~/.aws/credentials automatically.
AWS_PROFILE=Spark_users@710894194408

# Claude 3 Sonnet on-demand in us-east-1 (Sparkathon role can't use cross-region
# `us.` inference profiles due to explicit deny in us-east-2). Newer models
# require an inference profile and will fail with AccessDenied for this role.
BEDROCK_MODEL_ID=anthropic.claude-3-sonnet-20240229-v1:0

# NOTE: Do NOT put long-lived AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY here.
# Sessions expire hourly. When AWS calls start failing with `ExpiredToken`, re-run:
#   C:\MS_Entra_Auth\MSEntraAuthAWSCLI.exe i --all-accounts --default-session-duration 3600
