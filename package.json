{
  "name": "agent-best-call-workspace",
  "version": "1.0.0",
  "description": "Monorepo containing the Best Call of the Week frontend (Angular) and backend (Node.js/Express + AWS Bedrock)",
  "private": true,
  "scripts": {
    "start:backend": "cd Backend && npm start",
    "dev:backend": "cd Backend && npm run dev",
    "start:frontend": "cd Frontend && ng serve",
    "start": "concurrently \"npm run dev:backend\" \"npm run start:frontend\"",
    "install:all": "cd Backend && npm install"
  },
  "devDependencies": {
    "concurrently": "^8.2.0"
  }
}
